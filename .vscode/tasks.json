{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "npm: compile",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"compile"
			],
			"problemMatcher": [
				"$tsc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "npm: watch",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"watch"
			],
			"isBackground": true,
			"problemMatcher": [
				"$tsc-watch"
			],
			"group": {
				"kind": "build"
			}
		},
		{
			"label": "npm: lint",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"lint"
			],
			"problemMatcher": [
				"$eslint-stylish"
			]
		}
	]
}
